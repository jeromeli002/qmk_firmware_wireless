{
    "keyboard_name": "hlpad17",
    "manufacturer": "keymagichorse",
    "processor": "STM32F103",
    "bootloader": "stm32duino",
    "usb": {
        "vid": "0xBB03",
        "pid": "0xBB03",
        "device_version": "1.0.0"
    },
    "features": {
        "bootmagic": true,
        "command": false,
        "console": false,
        "extrakey": true,
        "mousekey": true,
        "bluetooth": true,
        "nkro": true,
        "rgb_matrix": true
    },
    "bluetooth":{
        "driver":"bhq"
    },
    "build": {
        "debounce_type": "sym_defer_pk",
        "lto": true
    },
    "debounce": 10,
    "matrix_pins": {
        "cols": ["C13", "C14", "B8", "B3"],
        "rows": ["B14", "B13", "A13", "A15", "B9"]
    },
    "rgb_matrix": {
        "animations": {
            "breathing": true,
            "cycle_all": true,
            "cycle_left_right": true,
            "cycle_up_down": true,
            "gradient_left_right": true,
            "gradient_up_down": true,
            "rainbow_pinwheels": true,
            "typing_heatmap": true,
            "solid_reactive": true,
            "solid_reactive_wide": true,
            "splash": true
        },
        // 150max
        "driver": "ws2812",
        "max_brightness": 150,
        "sleep": true,
        "led_count": 17
    },
    "ws2812": {
        "pin": "A9"
    },
    "diode_direction": "ROW2COL",
    "layouts": {
        "LAYOUT": {
            "layout": [
                { "matrix": [0, 0], "x": 0, "y": 0 },
                { "matrix": [0, 1], "x": 1, "y": 0 },
                { "matrix": [0, 2], "x": 2, "y": 0 },
                { "matrix": [0, 3], "x": 3, "y": 0 },

                { "matrix": [1, 0], "x": 0, "y": 1 },
                { "matrix": [1, 1], "x": 1, "y": 1 },
                { "matrix": [1, 2], "x": 2, "y": 1 },
                { "matrix": [1, 3], "x": 3, "y": 1 , "h": 2},

                { "matrix": [2, 0], "x": 0, "y": 2 },
                { "matrix": [2, 1], "x": 1, "y": 2 },
                { "matrix": [2, 2], "x": 2, "y": 2 },

                { "matrix": [3, 0], "x": 0, "y": 3 },
                { "matrix": [3, 1], "x": 1, "y": 3 },
                { "matrix": [3, 2], "x": 2, "y": 3 },

                { "matrix": [4, 0], "x": 3, "y": 3, "h": 2 },
                { "matrix": [4, 2], "w": 2, "x": 0, "y": 4 },
                { "matrix": [4, 3], "x": 2, "y": 4 }
            ]
        }
    }
}
